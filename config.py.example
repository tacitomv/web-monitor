"""
Configuration settings for the web monitor.
Fill in your SMTP credentials and customize the monitored targets.
"""

# =============================================================================
# SMTP EMAIL CONFIGURATION
# =============================================================================

SMTP_SERVER = ""  # SMTP server address (e.g., smtp.gmail.com)
SMTP_PORT = 587  # SMTP port (587 for TLS, 465 for SSL)
SMTP_USERNAME = ""  # Your email address
SMTP_PASSWORD = ""  # Your email password or app-specific password
SMTP_USE_TLS = False  # Use TLS encryption

SENDER_EMAIL = ""  # Sender email address
DEFAULT_RECIPIENT_EMAILS = [
    # "fallback@example.com",
]
RECIPIENT_EMAILS = DEFAULT_RECIPIENT_EMAILS

# =============================================================================
# MONITORED TARGETS CONFIGURATION
# =============================================================================
# Each entry should have:
#   - url: The page URL to monitor
#   - name: A friendly name for logging/notifications
#   - type: "table" or "uptime"
#   - recipients: Email list for this specific target
#   - table_id: Required only for type == "table"

MONITORED_TARGETS = [
    {
        "url": "https://example.com/procurement",
        "table_id": "documents-table",
        "name": "Procurement Documents",
        "type": "table",
        "recipients": ["procurement@example.com"],
    },
    {
        "url": "https://status.example.com/health",
        "name": "Public Status Page",
        "type": "uptime",
        "recipients": ["ops@example.com"],
    },
]

# =============================================================================
# MONITORING SETTINGS
# =============================================================================

CHECK_INTERVAL = 300  # How often to check for changes, in seconds

DAILY_REPORT_ENABLED = True
DAILY_REPORT_TIME = "18:00"  # Time to send daily report (24h format)

DATABASE_PATH = "monitor_state.db"

LOG_FILE = "monitor.log"
LOG_LEVEL = "INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL

REQUEST_TIMEOUT = 30  # Timeout for HTTP requests in seconds
USER_AGENT = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"